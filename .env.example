# ── Local development ─────────────────────────────────────────────────────────
# All values below match the docker-compose.yml defaults.
# For local development you do not need to create a .env file at all —
# every variable has a hardcoded fallback in the source code.
#
# The only variable you MUST set in production is JWT_SECRET.
# AI provider keys are entered through the Settings page in the UI and
# stored in the database — they are not read from environment variables.

# DATABASE_URL=postgresql://intel:intel@localhost:5435/reddit_intel
# REDIS_URL=redis://localhost:6381
# PORT=3001
# FRONTEND_URL=http://localhost:3000
# NEXT_PUBLIC_API_URL=http://localhost:3001

# ── Production only ───────────────────────────────────────────────────────────
# JWT_SECRET=         # Required — generate with: openssl rand -hex 32
